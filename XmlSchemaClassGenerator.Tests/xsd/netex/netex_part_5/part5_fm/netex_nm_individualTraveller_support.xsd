		</xsd:annotation>
		<xsd:restriction base="ObjectIdType"/>
	</xsd:simpleType>
	<xsd:element name="IndividualPassengerInfoRef" type="IndividualPassengerInfoRefStructure" substitutionGroup="VersionOfObjectRef">
		<xsd:annotation>
